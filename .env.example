# =============================================================================
# Multi-LLM Backend - Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the API keys you have.
# You only need to set keys for providers you want to use.
# The pipeline will automatically pick whichever provider is available and
# fall back to others on rate-limit / quota errors.
# =============================================================================

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins. Use "*" for all.
CORS_ORIGINS=*

# ---------- Provider order (lower priority = tried first) ----------
# Comma-separated provider names in the order you want them tried.
# Available: gemini,openrouter,groq,mistral,cohere,huggingface,claude,openai,grok
PROVIDER_ORDER=gemini,groq,openrouter,mistral,cohere,huggingface,claude,openai,grok

# ---------- Cooldown (seconds) when a provider hits rate-limit ----------
DEFAULT_COOLDOWN_SECONDS=60

# ---------- Request timeouts (seconds) ----------
REQUEST_TIMEOUT=120

# =============================================================================
# Free / freemium APIs (recommended)
# =============================================================================

# Google Gemini  -  https://aistudio.google.com/app/apikey  (free tier, supports vision + PDF)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# OpenRouter  -  https://openrouter.ai/keys  (many free models)
# OPENROUTER_MODELS / OPENROUTER_VISION_MODELS  =  comma-separated rotation list.
# The provider tries each model in order; if one is rate-limited / removed,
# it tries the next one before falling back to a different provider.
# Leave OPENROUTER_MODELS empty to use the single OPENROUTER_MODEL instead.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-4.5-air:free
OPENROUTER_VISION_MODEL=google/gemma-3-27b-it:free
OPENROUTER_MODELS=z-ai/glm-4.5-air:free,openai/gpt-oss-120b:free,nvidia/nemotron-3-super-120b-a12b:free,nousresearch/hermes-3-llama-3.1-405b:free,minimax/minimax-m2.5:free,google/gemma-3-27b-it:free,qwen/qwen3-next-80b-a3b-instruct:free,nvidia/nemotron-nano-9b-v2:free,meta-llama/llama-3.3-70b-instruct:free,openai/gpt-oss-20b:free,meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_VISION_MODELS=google/gemma-3-27b-it:free,google/gemma-3-12b-it:free,google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free,nvidia/nemotron-nano-12b-v2-vl:free,google/gemma-3-4b-it:free

# Groq  -  https://console.groq.com/keys  (free, very fast)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview

# Mistral  -  https://console.mistral.ai/api-keys/  (free tier)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_VISION_MODEL=pixtral-12b-2409

# Cohere  -  https://dashboard.cohere.com/api-keys  (free trial tier)
COHERE_API_KEY=
COHERE_MODEL=command-a-03-2025

# HuggingFace Inference  -  https://huggingface.co/settings/tokens  (free)
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct

# =============================================================================
# Paid / premium APIs (optional fallback)
# =============================================================================

# Anthropic Claude  -  https://console.anthropic.com/
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# OpenAI ChatGPT  -  https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# xAI Grok  -  https://console.x.ai/
GROK_API_KEY=
GROK_MODEL=grok-2-latest
GROK_VISION_MODEL=grok-2-vision-latest
